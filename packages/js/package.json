{
  "name": "img2num",
  "version": "0.2.1",
  "description": "Img2Num is a raster vectorization library - it converts images to SVGs",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "img2num",
    "computer-vision",
    "computer-vision",
    "vectorization",
    "image-to-svg"
  ],
  "homepage": "https://github.com/Ryan-Millard/Img2Num#readme",
  "bugs": {
    "url": "https://github.com/Ryan-Millard/Img2Num/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ryan-Millard/Img2Num.git"
  },
  "license": "MIT",
  "author": "Ryan-Millard",
  "type": "module",
  "main": "./dist/node/index.cjs",
  "scripts": {
    "build:browser": "cross-env TARGET=browser vite build",
    "build:node": "cross-env TARGET=node vite build",
    "build": "pnpm build:browser && pnpm build:node"
  },
  "engines": {
    "node": ">=14"
  },
  "exports": {
    ".": {
      "require": "./dist/node/index.cjs",
      "import": "./dist/node/index.js",
      "browser": "./dist/browser/img2num.es.js",
      "default": "./dist/node/index.js"
    }
  },
  "optionalDependencies": {
    "webgpu": "^0.4.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "vite": "^8.1.0"
  }
}
