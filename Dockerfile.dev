# --------------------------------------------------------------------------------------------------------------
# Img2Num Dockerfile.dev
#
# Be careful of how you update this file. Updating layer 2 forces the layers below it to rebuild, too!
# --------------------------------------------------------------------------------------------------------------

FROM node:22-trixie

# --------------------------------------------------------------------------------------------------------------
# Build metadata
ARG BUILD_DATE
ARG GIT_SHA

LABEL org.opencontainers.image.title="Img2Num Dev"
LABEL org.opencontainers.image.description="Development environment for Img2Num"
LABEL org.opencontainers.image.source="https://github.com/Ryan-Millard/Img2Num"
LABEL org.opencontainers.image.created=$BUILD_DATE
LABEL org.opencontainers.image.revision=$GIT_SHA

# --------------------------------------------------------------------------------------------------------------
# OS setup & core tooling
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
      build-essential \
      gcc-14 \
      g++-14 \
      clang \
      cmake \
      ninja-build \
      python3 \
      python3-setuptools \
      python3-wheel \
      python3-pybind11 \
      git \
      curl \
      unzip \
      pkg-config \
      bash \
      ca-certificates \
      tzdata \
    && rm -rf /var/lib/apt/lists/*

ENV TZ=Africa/Johannesburg

ENV CC=gcc-14
ENV CXX=g++-14

ENV SHELL=/bin/bash
SHELL ["/bin/bash", "-c"]

WORKDIR /usr/src/app

# --------------------------------------------------------------------------------------------------------------
# Git safety
RUN git config --global --add safe.directory /usr/src/app

# --------------------------------------------------------------------------------------------------------------
# Emscripten setup (Slightly Expensive)
ENV EMSDK_VERSION=4.0.10
ENV EMSDK_DIR=/opt/emsdk

RUN git clone --depth 1 https://github.com/emscripten-core/emsdk.git $EMSDK_DIR \
  && cd $EMSDK_DIR \
  && git fetch --tags \
  && git checkout $EMSDK_VERSION \
  && ./emsdk install $EMSDK_VERSION \
  && ./emsdk activate $EMSDK_VERSION

ENV PATH=$EMSDK_DIR:$EMSDK_DIR/upstream/emscripten:$PATH
ENV EMSDK=$EMSDK_DIR

# Auto-load emsdk in all shells
RUN echo "source /opt/emsdk/emsdk_env.sh" >> /etc/bash.bashrc

# --------------------------------------------------------------------------------------------------------------
# Dawn dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
      libvulkan1 \
      mesa-vulkan-drivers \
      libgl1-mesa-dev \
      libglu1-mesa-dev \
      vulkan-tools \
      libvips-dev \
    && rm -rf /var/lib/apt/lists/*

# --------------------------------------------------------------------------------------------------------------
# Dawn build (expensive layer)
COPY third_party/dawn third_party/dawn

RUN cmake -S third_party/dawn -B build/dawn \
    -DDAWN_SUPPORTS_GLFW_FOR_WINDOWING=OFF \
    -DDAWN_USE_X11=OFF \
    -DDAWN_FETCH_DEPENDENCIES=ON \
    -DDAWN_ENABLE_INSTALL=ON \
    -DDAWN_BUILD_TESTS=OFF \
    -DCMAKE_BUILD_TYPE=Release \
  && cmake --build build/dawn --parallel $(nproc) \
  && cmake --install build/dawn

# --------------------------------------------------------------------------------------------------------------
# Doxygen
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
      doxygen \
      graphviz \
    && rm -rf /var/lib/apt/lists/*

# --------------------------------------------------------------------------------------------------------------
# UV + Python environment
RUN curl -LsSf https://astral.sh/uv/0.5.1/install.sh | sh

ENV PATH="/root/.local/bin:${PATH}"
ENV UV_LINK_MODE=copy
ENV UV_PIP_CACHE_DIR=/root/.cache/uv/pip

RUN uv venv /usr/src/app/.venv

ENV VIRTUAL_ENV=/usr/src/app/.venv
ENV PATH="/usr/src/app/.venv/bin:$PATH"

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install scikit_build_core numpy

# --------------------------------------------------------------------------------------------------------------
# Node / pnpm setup
RUN corepack enable \
  && corepack prepare pnpm@11.4.0 --activate

ENV PNPM_STORE_DIR=/pnpm/store
ENV PATH=/root/.local/share/pnpm:$PATH

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/js/package.json packages/js/package.json
COPY docs/package.json docs/package.json
COPY example-apps/react-js/package.json example-apps/react-js/package.json
COPY scripts/img2num-dev-scripts/package.json scripts/img2num-dev-scripts/package.json

RUN --mount=type=cache,target=/pnpm/store \
    pnpm install --no-frozen-lockfile

# --------------------------------------------------------------------------------------------------------------
# Dev UX settings
ENV CHOKIDAR_USEPOLLING=true
ENV CHOKIDAR_INTERVAL=100

EXPOSE 5173 3000

# --------------------------------------------------------------------------------------------------------------
# Healthcheck (Basic if container works)
HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
  CMD bash -lc "\
    node --version >/dev/null && \
    corepack pnpm --version >/dev/null && \
    emcc --version >/dev/null && \
    cmake --version >/dev/null"

CMD ["bash"]
